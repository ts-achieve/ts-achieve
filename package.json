{
  "name": "ts-achieve",
  "repository": {
    "url": "https://github.com/ts-achieve/ts-achieve.git"
  },
  "displayName": "ts-achieve",
  "description": "TypeScript errors as achievements",
  "version": "0.0.26",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tsAchieve.command.refresh",
        "title": "Refresh Achievements"
      },
      {
        "command": "tsAchieve.command.startrun",
        "title": "Start New Run"
      },
      {
        "command": "tsAchieve.command.stoprun",
        "title": "Stop Current Run"
      },
      {
        "command": "tsAchieve.command.hardReset",
        "title": "Hard Reset",
        "icon": "lib/typescript.svg"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tsAchieve.command.hardReset",
          "when": "view == tsAchieve",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TS Achieve",
      "type": "object",
      "properties": {
        "tsAchieve.config.revealDescription": {
          "type": "boolean",
          "default": false,
          "description": "Whether a locked achievement should reveal its description. (default: false)"
        },
        "tsAchieve.config.notifyRepeatedAchievements": {
          "type": "boolean",
          "default": false,
          "description": "Whether to show information message on achievements that are already earned. (default: false)"
        },
        "tsAchieve.config.sort": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "kind (errors first)",
              "kind (errors last)",
              "locked first",
              "unlocked first",
              "code (ascending)",
              "code (descending)",
              "alphabetic (forwards)",
              "alphabetic (backwards)"
            ]
          },
          "default": [
            "kind (errors last)",
            "locked first",
            "code (ascending)"
          ],
          "description": "The ordered list of properties by which to sort. (experimental)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tsAchieve",
          "title": "Achievements",
          "icon": "lib/typescript.svg"
        }
      ]
    },
    "views": {
      "tsAchieve": [
        {
          "id": "tsAchieve.view.summary",
          "name": "Summary",
          "icon": "lib/typescript.svg"
        },
        {
          "id": "tsAchieve.view.list",
          "name": "List",
          "icon": "lib/typescript.svg"
        },
        {
          "id": "tsAchieve.view.speedrun",
          "name": "Speedrun",
          "icon": "lib/typescript.svg"
        }
      ]
    }
  },
  "scripts": {
    "r": "rm -rf out && rm -f pnpm-lock.yaml && rm -rf node_modules && pnpm install",
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile",
    "test": "vscode-test --run",
    "p": "pnpm exec vsce-pnpm patch"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.9.3",
    "vsce-pnpm": "^0.1.0"
  },
  "dependencies": {
    "expect-type": "^1.3.0"
  }
}
