{
  "name": "ts-achieve",
  "displayName": "ts-achieve",
  "description": "TypeScript errors as achievements",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tsAchieve.show",
        "title": "Show Achievements"
      },
      {
        "command": "tsAchieve.refresh",
        "title": "Refresh Achievements"
      }
    ],
    "configuration": {
      "title": "ts-achieve",
      "type": "object",
      "properties": {
        "tsAchieve.config.doesShowDescription": {
          "type": "boolean",
          "default": false,
          "description": "Whether a locked achievement should reveal its description."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "achieves",
          "title": "Achievements",
          "icon": "lib/typescript.svg"
        }
      ]
    },
    "views": {
      "achieves": [
        {
          "id": "tsAchieve.view.list",
          "name": "List",
          "icon": "lib/typescript.svg"
        },
        {
          "id": "tsAchieve.view.speedrun",
          "name": "Speedrun",
          "icon": "lib/typescript.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile",
    "test": "vitest --run && vscode-test --run"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "vitest": "^4.1.0"
  }
}
