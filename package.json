{
  "name": "ts-achieve",
  "publisher": "ts-achieve",
  "repository": {
    "url": "https://github.com/ts-achieve/ts-achieve.git"
  },
  "displayName": "ts-achieve",
  "description": "TypeScript errors as achievements: gamify the development experience",
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers",
    "Visualization",
    "Education"
  ],
  "keywords": [
    "ts",
    "typescript",
    "star",
    "achieve",
    "achievement",
    "error",
    "warning",
    "suggestion",
    "message",
    "game",
    "gamify",
    "unlock",
    "lock",
    "encounter",
    "speedrun"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tsAchieve.command.refresh",
        "title": "Refresh Achievements",
        "icon": "$(refresh)"
      },
      {
        "command": "tsAchieve.command.hardReset",
        "title": "Hard Reset",
        "icon": "$(trash)"
      },
      {
        "command": "tsAchieve.command.showUnlocked",
        "title": "Click to show unlocked achievements",
        "icon": "$(star-half)"
      },
      {
        "command": "tsAchieve.command.showLocked",
        "title": "Click to show locked achievements",
        "icon": "$(star-full)"
      },
      {
        "command": "tsAchieve.command.showAll",
        "title": "Click to show all achievements",
        "icon": "$(star-empty)"
      },
      {
        "command": "tsAchieve.command.logStarmap",
        "title": "Log starmap to console",
        "icon": "$(pencil)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tsAchieve.command.showUnlocked",
          "when": "view == tsAchieve.view.list && tsAchieve.showing == 0",
          "group": "navigation"
        },
        {
          "command": "tsAchieve.command.showLocked",
          "when": "view == tsAchieve.view.list && tsAchieve.showing == 1",
          "group": "navigation"
        },
        {
          "command": "tsAchieve.command.showAll",
          "when": "view == tsAchieve.view.list && tsAchieve.showing == 2",
          "group": "navigation"
        },
        {
          "command": "tsAchieve.command.logStarmap",
          "when": "view == tsAchieve.view.list",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TS Achieve",
      "type": "object",
      "properties": {
        "tsAchieve.config.revealDescription": {
          "type": "boolean",
          "default": false,
          "description": "Whether a locked achievement should reveal its description. (default: false)"
        },
        "tsAchieve.config.notifyOnReachieve": {
          "type": "boolean",
          "default": false,
          "description": "Whether to show information message on achievements that are already earned. (default: false)"
        },
        "tsAchieve.config.subcategorize": {
          "type": "string",
          "enum": [
            "none",
            "achievements only",
            "all"
          ],
          "default": "all",
          "description": "How to subcategorize achievements (default: all)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tsAchieve",
          "title": "Achievements",
          "icon": "$(star-empty)"
        }
      ]
    },
    "views": {
      "tsAchieve": [
        {
          "id": "tsAchieve.view.summary",
          "name": "Summary",
          "icon": "$(preview)"
        },
        {
          "id": "tsAchieve.view.list",
          "name": "List",
          "icon": "$(list-tree)"
        },
        {
          "type": "webview",
          "id": "tsAchieve.view.speedrun",
          "name": "Speedrun",
          "icon": "$(symbol-event)"
        },
        {
          "type": "webview",
          "id": "tsAchieve.view.liveblog",
          "name": "Liveblog",
          "icon": "$(dashboard)"
        }
      ]
    }
  },
  "scripts": {
    "r": "rm -rf .vscode-test && rm -rf out && rm -f pnpm-lock.yaml && rm -rf node_modules",
    "ri": "pnpm r && pnpm i",
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "rm -rf out && pnpm run compile",
    "test": "vscode-test run",
    "w": "tsc webview/liveblogger/worker.ts --ignoreConfig --module esnext --sourceMap false && sed -i '' '$d' webview/liveblogger/worker.js",
    "p": "pnpm exec vsce-pnpm patch"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.110.0",
    "@types/vscode-webview": "^1.57.5",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^6.0.2",
    "vsce-pnpm": "^0.1.0"
  },
  "dependencies": {
    "chai": "^6.2.2",
    "expect-type": "^1.3.0"
  },
  "packageManager": "pnpm@9.12.2"
}
