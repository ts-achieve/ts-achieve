{
  "name": "ts-achieve",
  "displayName": "ts-achieve",
  "description": "TypeScript errors as achievements",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "achievements.show",
        "title": "Show Achievements"
      },
      {
        "command": "achievements.refresh",
        "title": "Refresh Achievements"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "achievements",
          "title": "Achievements",
          "icon": "lib/typescript.svg"
        }
      ]
    },
    "views": {
      "achievements": [
        {
          "id": "achievementsList",
          "name": "",
          "icon": "lib/typescript.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile",
    "test": "vitest --run && vscode-test"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "vitest": "^4.1.0"
  }
}
